# Template for .env.local: copy these keys and fill in your Supabase project's URL + anon key
# (Supabase dashboard -> Settings -> API).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push VAPID public key — generate a pair with `npx web-push generate-vapid-keys`.
# The public key goes here; the private key is a Supabase Edge Function secret, not an env var.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
